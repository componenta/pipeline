{
    "name": "componenta/pipeline",
    "description": "PSR-15 middleware pipeline for Componenta",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Http\\Middleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\Http\\Middleware\\Tests\\": "tests/"
        }
    },
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Http\\Middleware\\PipelineConfigProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
